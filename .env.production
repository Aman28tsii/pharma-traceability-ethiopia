# Production Environment Variables for Render
NODE_ENV=production
PORT=5000

# Database - Use your NEON connection string
DATABASE_URL=postgresql://user:password@ep-cool-limit-123456.eu-central-1.aws.neon.tech/pharma_traceability_db?sslmode=require

# JWT Secret - CHANGE THIS TO A RANDOM STRING
JWT_SECRET=your-super-secret-jwt-key-change-this-production-2024

# CORS Settings
CORS_ORIGIN=https://your-app-name.onrender.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100